{
  "respectGitignore": false,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv",
            "args": [
              "run",
              "--no-project",
              "${CLAUDE_PROJECT_DIR}/.claude/hooks/journal_inject.py"
            ]
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run markitdown:*)",
      "Bash(uv run startup.py:*)",
      "Bash(caption:*)",
      "Bash(uv run nd.py:*)",
      "Bash(uv tool install --force --python 3.13 \"caption-cli @ git+https://github.com/sec-chair/caption-cli.git\")",
      "Bash(.venv/bin/adeu:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ]
  }
}
