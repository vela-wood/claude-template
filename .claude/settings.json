{
  "respectGitignore": false,
  "permissions": {
    "allow": [
      "Bash(uv run markitdown:*)",
      "Bash(uv run startup.py:*)",
      "Bash(.claude/skills/redline/scripts/run_redline.sh:*)",
      "Bash(.venv/bin/adeu:*)",
      "Bash(.venv/bin/caption:*)",
      "Bash(grep:*)",
      "Bash(find:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "clawmoat scan"
          }
        ]
      }
    ]
  }
}
